# Aurion Nexus — Environment Template
# Copy this to .env and fill in the values.

# GitHub Personal Access Token (for repository ingestion and global install)
# github_token=ghp_...

# WikiMind Central Knowledge OS URL
# WIKIMIND_URL=http://localhost:7842

# Optional: Agent API keys if not using default os-level env vars
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
