#!/usr/bin/env python3
import sys
from rich.console import Console
from rich.panel import Panel
from rich.tree import Tree

console = Console()

def show_traces():
    console.print(Panel("[bold magenta]🔍 Aurion Nexus — Distributed Trace Explorer (Sovereign Observability)[/bold magenta]"))
    
    # In a real OTel implementation, we would pull from a collector.
    # Here we present a structured visualization of a successful trace.
    
    tree = Tree("[bold cyan]Trace: mission_execution (0xae42...)[/bold cyan]")
    aurion = tree.add("[blue]Aurion: Strategy & Alignment[/blue] [dim]240ms[/dim]")
    aurion.add("Intent Analysis [dim]45ms[/dim]")
    aurion.add("Maturity Assessment (SEIP v2) [dim]120ms[/dim]")
    aurion.add("Decision: Accepted [dim]10ms[/dim]")
    
    aurora = tree.add("[cyan]Aurora: Implementation[/cyan] [dim]1.2s[/dim]")
    aurora.add("Context Retrieval (WikiMind RAG) [dim]450ms[/dim]")
    aurora.add("Code Synthesis [dim]700ms[/dim]")
    
    shield = tree.add("[green]Shield: Safety Verification[/green] [dim]80ms[/dim]")
    shield.add("PII Scan [dim]20ms[/dim]")
    shield.add("Semantic Guardrails [dim]60ms[/dim]")
    
    console.print(tree)
    console.print(f"\n[bold]Total Path Latency:[/bold] [bold magenta]1.52s[/bold magenta]")

if __name__ == "__main__":
    show_traces()
