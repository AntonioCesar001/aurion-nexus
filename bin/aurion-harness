#!/usr/bin/env python3
import os
import sys
from datetime import datetime
from rich.console import Console
from rich.panel import Panel
from rich.table import Table

console = Console()

WORKSPACE_ROOT = "/Users/ton_dev/desenvolvimento/aurion-nexus"

REQUIRED_FILES = [
    ".agent/docs/RULES.md",
    ".agent/docs/AGENTS.md",
    ".agent/docs/CHRONICLE.md",
    "CLAUDE.md"
]

def check_harness_integrity():
    console.print("[bold blue]🛡️ Running Aurion Harness Integrity Check...[/bold blue]")
    
    table = Table(title="Harness Health Report", border_style="cyan")
    table.add_column("Asset", style="bold")
    table.add_column("Status")
    table.add_column("Remarks")

    errors = 0
    for file in REQUIRED_FILES:
        path = os.path.join(WORKSPACE_ROOT, file)
        if os.path.exists(path):
            status = "[green]✓ OK[/green]"
            size = os.path.getsize(path)
            table.add_row(file, status, f"{size} bytes")
        else:
            status = "[red]✗ MISSING[/red]"
            table.add_row(file, status, "Critical failure!")
            errors += 1

    # Check PULSE.md freshness
    pulse_path = os.path.join(WORKSPACE_ROOT, "PULSE.md")
    if os.path.exists(pulse_path):
        mtime = os.path.getmtime(pulse_path)
        dt = datetime.fromtimestamp(mtime)
        now = datetime.now()
        diff = now - dt
        if diff.total_seconds() > 3600: # 1 hour
            table.add_row("PULSE.md", "[yellow]! STALE[/yellow]", f"Last updated {diff.total_seconds() / 60:.1f} mins ago")
        else:
            table.add_row("PULSE.md", "[green]✓ FRESH[/green]", "Up to date")
    else:
        table.add_row("PULSE.md", "[red]✗ MISSING[/red]", "Run 'aurion pulse' to synchronize")
        errors += 1

    console.print(table)
    
    if errors > 0:
        console.print(Panel(f"[bold red]Harness Compromised![/bold red] {errors} critical errors found.\nAgents must correct these before proceeding.", border_style="red"))
        return False
    else:
        console.print(Panel("[bold green]Harness Operational.[/bold green] Ready for autonomous execution.", border_style="green"))
        return True

def main():
    import sys
    if len(sys.argv) > 1 and sys.argv[1] == "--validate":
        success = check_harness_integrity()
        sys.exit(0 if success else 1)
    else:
        # Default behavior: show help or just run check
        check_harness_integrity()

if __name__ == "__main__":
    main()
