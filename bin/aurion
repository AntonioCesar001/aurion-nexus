#!/bin/bash
# 🏛️ Aurion Nexus — Unified Sovereign CLI

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PARENT_DIR="$(dirname "$DIR")"

# Elite Logic Bypass
if [ -f "$DIR/aurion.py" ]; then
    if [ -f "$PARENT_DIR/.venv/bin/python3" ]; then
        PYTHON_EXEC="$PARENT_DIR/.venv/bin/python3"
    else
        PYTHON_EXEC="python3"
    fi
    # Only pass specific commands to elite UI for now
    case "${1:-}" in
        status|health|mission)
            $PYTHON_EXEC "$DIR/aurion.py" "$@"
            exit $?
            ;;
    esac
fi


usage() {
    echo -e "${BLUE}Aurion Nexus CLI — Sovereign Agentic Control${NC}"
    echo "Usage: aurion <command> [args]"
    echo ""
    echo "Commands:"
    echo "  health           Run the health engine diagnostics"
    echo "  pulse            Generate/refresh the context snapshot (PULSE.md)"
    echo "  mission <goal>   Initialize an autonomous mission (Ralph loop)"
    echo "  dispatch-bg <g>  Spawn a sandboxed background mission process"
    echo "  status           Show the current state of the sovereign core"
    echo "  setup            Run the initial skills registration"
    echo "  help             Show this help message"
}

case "$1" in
    health)
        "$DIR/health-check.sh"
        ;;
    pulse)
        "$DIR/project-pulse.sh"
        ;;
    mission)
        if [ -z "${2:-}" ]; then
            echo -e "${RED}Error: Mission goal required.${NC}"
            exit 1
        fi
        GOAL="$2"
        echo -e "${YELLOW}🚀 Initializing Mission: $GOAL${NC}"
        
        # Phase 1: Planning (Aurion)
        echo -e "${BLUE}[Aurion]${NC} Analyzing strategy and maturity gaps..."
        
        # Phase 2: Execution Loop (Aurora)
        MAX_RETRIES=3
        RETRY_COUNT=0
        SUCCESS=false
        
        while [ $RETRY_COUNT -lt $MAX_RETRIES ]; do
            echo -e "${CYAN}[Aurora]${NC} Attempt $((RETRY_COUNT+1)): Implementing goal..."
            # Here we would call the agent CLI or toolkit
            # For this execution, we simulate a check
            if [ -f "PULSE.md" ]; then
                echo -e "${GREEN}✅ Verification passed.${NC}"
                SUCCESS=true
                break
            else
                echo -e "${YELLOW}⚠️ Verification failed. Starting Ralph Loop correction...${NC}"
                RETRY_COUNT=$((RETRY_COUNT+1))
            fi
        done
        
        if [ "$SUCCESS" = true ]; then
            echo -e "${GREEN}🌟 Mission Accomplished!${NC}"
            "$DIR/project-pulse.sh"
        else
            echo -e "${RED}❌ Mission Failed after $MAX_RETRIES attempts.${NC}"
            exit 1
        fi
        ;;

    dispatch-bg)
        if [ -z "$2" ]; then
            echo -e "${RED}Error: Mission goal required for background dispatch.${NC}"
            exit 1
        fi
        
        SESSION_ID=$(date +%s)
        GOAL="$2"
        LOG_FILE="$PARENT_DIR/mission_$(date +%Y%m%d_%H%M%S).log"
        
        echo -e "${BLUE}📡 Dispatching Mission to Background Agent...${NC}"
        
        # Start a persistent agent process
        nohup bash -c "
            echo '--- Mission Log Start: $GOAL ---' >> '$LOG_FILE'
            echo '[Plan] Generating SEIP v2 strategy...' >> '$LOG_FILE'
            # Simulating agent loop
            for i in {1..3}; do
                echo \"[Iterate \$i] Executing step \$i...\" >> \"$LOG_FILE\"
                sleep 2
            done
            echo '🌟 Goal reached: $GOAL' >> '$LOG_FILE'
            echo '--- Mission Log End ---' >> '$LOG_FILE'
        " >/dev/null 2>&1 &
        
        echo -e "${GREEN}Background agent detached successfully (PID $!).${NC}"
        echo "Monitoring output: tail -f $LOG_FILE"
        ;;
    status)
        echo -e "${BLUE}--- Core Status ---${NC}"
        if [ -f "$PARENT_DIR/CHRONICLE.md" ]; then
            tail -n 10 "$PARENT_DIR/CHRONICLE.md"
        else
            echo "Chronicle not found."
        fi
        ;;
    setup|link)
        "$PARENT_DIR/scripts/setup-skills.sh"
        ;;
    *)
        usage
        ;;
esac
