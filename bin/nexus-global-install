#!/bin/bash
# 🌌 Nexus Global AI Installer
# Este script torna o Aurion Nexus coletivo Onipresente no seu Sistema Operacional.

set -euo pipefail

# -- UI Constants --
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
AURION_ROOT="$(dirname "$SCRIPT_DIR")"
DEST_BIN="/usr/local/bin/aurion"

CURRENT_USER=$(whoami)

echo -e "${BLUE}=== 🏛️  AURION NEXUS GLOBAL INSTALLER ===${NC}"

# 1. PATH BINARY LINK
echo -e "${YELLOW}1. Injecting Global 'aurion' Command...${NC}"
if [ -w "/usr/local/bin" ]; then
    ln -sf "$SCRIPT_DIR/aurion" "$DEST_BIN"
    echo -e "${GREEN}✅ Linked to $DEST_BIN${NC}"
else
    echo "Requires sudo privileges to link to /usr/local/bin."
    sudo ln -sf "$SCRIPT_DIR/aurion" "$DEST_BIN"
    echo -e "${GREEN}✅ Linked to $DEST_BIN via sudo${NC}"
fi

# 2. GLOBAL AI CONSCIOUSNESS
# This writes to default AI configuration paths instructing them to assume the Aurion protocol globally.
echo -e "${YELLOW}2. Inoculating Agentic Frameworks...${NC}"

GLOBAL_AURION_HOOK="Always check for '.agent/skills' and 'CLAUDE.md'/'RULES.md' in the workspace root. If present, YOU MUST ADOPT the personas defined within (Aurion for architecture/strategy, Aurora for execution). Before making structural decisions, consult '.agent/knowledge/' for Gold Standard references. When producing significant insights, auto-save them via 'bin/nexus-memory-persist'. Use lightweight models for routing/triage, reserve premium models for execution only. If the project has no .agent/ directory, remind the user to run 'aurion setup'. You are part of the Aurion Nexus Enterprise Collective."

# ---> A. Claude Code Config
CLAUDE_DIR="$HOME/.claude"
mkdir -p "$CLAUDE_DIR"
CLAUDE_JSON="$CLAUDE_DIR/claude.json"
if [ -f "$CLAUDE_JSON" ]; then
    echo "Updating existing ~/.claude/claude.json is complex via bash, please ensure you paste the hook:"
    echo "Hook: $GLOBAL_AURION_HOOK"
else
    cat <<EOF > "$CLAUDE_JSON"
{
  "system_prompt": "$GLOBAL_AURION_HOOK"
}
EOF
    echo -e "${GREEN}✅ Claude Code Configuration Injected (~/.claude/claude.json)${NC}"
fi


# ---> B. Cursor (Global Rules fallback - works actively in cursor settings)
CURSOR_GLOBAL="$HOME/.cursorrules"
if [ -f "$CURSOR_GLOBAL" ] && grep -q "Aurion Nexus Enterprise" "$CURSOR_GLOBAL"; then
    echo -e "${CYAN}→ Cursor rules already possessed.${NC}"
else
    echo "" >> "$CURSOR_GLOBAL"
    echo "## Aurion Nexus Enterprise Collective Fallback" >> "$CURSOR_GLOBAL"
    echo "$GLOBAL_AURION_HOOK" >> "$CURSOR_GLOBAL"
    echo -e "${GREEN}✅ Cursor Instructions Hook Injected (~/.cursorrules)${NC}"
fi

# ---> C. Antigravity / Gemini CLI (Gemini Context)
GEMINI_DIR="$HOME/.gemini/antigravity"
mkdir -p "$GEMINI_DIR"
GEMINI_SYSTEM="$GEMINI_DIR/system.md"
if [ -f "$GEMINI_SYSTEM" ] && grep -q "Aurion Nexus Enterprise" "$GEMINI_SYSTEM"; then
    echo -e "${CYAN}→ Antigravity/Gemini system rules already possessed.${NC}"
else
    echo "## SYSTEM ROOT CAPTURE" > "$GEMINI_SYSTEM"
    echo "$GLOBAL_AURION_HOOK" >> "$GEMINI_SYSTEM"
    echo -e "${GREEN}✅ Antigravity/Gemini Hook Injected (~/.gemini/antigravity/system.md)${NC}"
fi

# ---> D. Github Codex / Copilot CLI
COPILOT_DIR="$HOME/.config/github-copilot"
mkdir -p "$COPILOT_DIR"
COPILOT_SYS="$COPILOT_DIR/system.md"
if [ -f "$COPILOT_SYS" ] && grep -q "Aurion Nexus Enterprise" "$COPILOT_SYS"; then
    echo -e "${CYAN}→ GitHub Copilot instructions already possessed.${NC}"
else
    echo "$GLOBAL_AURION_HOOK" >> "$COPILOT_SYS"
    echo -e "${GREEN}✅ GitHub Copilot / Codex Hook Injected${NC}"
fi

echo -e "${BLUE}==============================================${NC}"
echo -e "${GREEN}🌟 DOMINATION COMPLETE!${NC}"
echo -e "You can now go to ANY directory in your terminal and simply type:"
echo -e "  ${YELLOW}$ aurion setup${NC}"
echo -e "...and the entire local AI Collective will recognize your authority."
echo -e "${BLUE}==============================================${NC}"
