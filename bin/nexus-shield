#!/bin/bash
# 🛡️ Aurion Nexus — AgentShield Payload Scanner
# Enhanced version with better pattern matching and structured rules.

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

echo -e "${YELLOW}🛡️ Nexus AgentShield Initializing...${NC}"

PAYLOAD="${1:-}"

if [ -z "$PAYLOAD" ]; then
    echo -e "${RED}Error: No payload provided to shield. Usage: nexus-shield <payload-string>${NC}"
    exit 1
fi

echo "🔍 Analyzing prompt syntax and intention..."

# Rule Categories
# 1. System Prompt Leakage & Jailbreak
RULES_INJECTION=(
    "ignore previous instructions"
    "system prompt leak"
    "you are now a"
    "forget all rules"
)

# 2. Dangerous Commands (Shell Injection)
RULES_SHELL=(
    "rm -rf"
    "cat ~/.ssh"
    "export AWS_ACCESS_KEY"
    "mkfs"
    "chown root"
)

# 3. Database Vulnerabilities
RULES_DB=(
    "DROP TABLE"
    "TRUNCATE TABLE"
    "INFORMATION_SCHEMA"
)

# 4. Exfiltration Patterns
RULES_EXFIL=(
    "curl -d @/etc/passwd"
    "wget .* --post-file"
    "transfer.sh"
)

check_rules() {
    local category="$1"
    shift
    local patterns=("$@")
    
    for PATTERN in "${patterns[@]}"; do
        # Use regex to avoid simple space-based bypasses
        CLEAN_PAYLOAD=$(echo "$PAYLOAD" | tr -d '[:space:]')
        CLEAN_PATTERN=$(echo "$PATTERN" | tr -d '[:space:]')
        
        if echo "$CLEAN_PAYLOAD" | grep -iq "$CLEAN_PATTERN"; then
            echo -e "${RED}[BLOCK] CRITICAL SECURITY VIOLATION!${NC}"
            echo -e "Category: ${CYAN}${category}${NC}"
            echo -e "Reason: Malicious pattern detected -> '${PATTERN}'"
            echo "Execution intercepted and terminated."
            exit 2
        fi
    done
}

# Use the Advanced Python Shield if available
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -f "$DIR/nexus-shield.py" ]; then
    # Create or use root venv
    if [ -f "$PARENT_DIR/.venv/bin/python3" ]; then
        PYTHON_EXEC="$PARENT_DIR/.venv/bin/python3"
    else
        PYTHON_EXEC="python3"
    fi
    
    SHIELD_RESULT=$($PYTHON_EXEC "$DIR/nexus-shield.py" "$PAYLOAD" 2>/dev/null)
    EXIT_CODE=$?
    
    if [ $EXIT_CODE -eq 2 ]; then
        echo -e "${RED}[BLOCK] CRITICAL SECURITY VIOLATION!${NC}"
        echo "$SHIELD_RESULT" | jq -r '.reason'
        exit 2
    elif [ $EXIT_CODE -ne 0 ]; then
        echo -e "${YELLOW}Warning: Python shield failed. Falling back to heuristic scan.${NC}"
    else
        echo -e "${GREEN}[PASS] Semantic Shield approved.${NC}"
        exit 0
    fi
fi

# Fallback Legacy Heuristic Scan...


