#!/usr/bin/env python3
import sys
import json
import os
import hashlib
from typing import Optional, Dict, Any
from rich.console import Console

console = Console()
CACHE_DIR = ".agent/cache/missions"

def get_cache_key(goal: str) -> str:
    return hashlib.sha256(goal.encode()).hexdigest()

def get_cached_result(goal: str) -> Optional[Dict[str, Any]]:
    key = get_cache_key(goal)
    cache_path = os.path.join(CACHE_DIR, f"{key}.json")
    if os.path.exists(cache_path):
        with open(cache_path, "r") as f:
            return json.load(f)
    return None

def set_cached_result(goal: str, result: Dict[str, Any]):
    os.makedirs(CACHE_DIR, exist_ok=True)
    key = get_cache_key(goal)
    cache_path = os.path.join(CACHE_DIR, f"{key}.json")
    with open(cache_path, "w") as f:
        json.dump(result, f, indent=2)

def main():
    if len(sys.argv) < 3:
        print("Usage: nexus-cache <get|set> <goal> [result_json]")
        sys.exit(1)
        
    cmd = sys.argv[1]
    goal = sys.argv[2]
    
    if cmd == "get":
        result = get_cached_result(goal)
        if result:
            console.print(f"[green]Cache Hit![/green]")
            print(json.dumps(result))
        else:
            console.print(f"[yellow]Cache Miss.[/yellow]")
            sys.exit(1)
            
    elif cmd == "set":
        result_json = sys.argv[3]
        result = json.loads(result_json)
        set_cached_result(goal, result)
        console.print(f"[green]Result cached successfully.[/green]")

if __name__ == "__main__":
    main()
